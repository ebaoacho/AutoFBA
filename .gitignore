# Project-wide ignore rules for LOGEX

# Node / frontend dependencies
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Next.js build output
.next/
out/
build/

# Python / Django
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.pyc.*
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
.venv/
venv/
env/
ENV/

# Local databases and runtime files
*.sqlite3
*.sqlite3-*
*.db
*.log
*.pid

# Coverage / reports
coverage/

# Environment files and secrets
.env
.env.*
!.env.example
!.env*.example
*.pem
*.key
*.crt

# Editor / IDE
.vscode/
.idea/
*.code-workspace

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Tooling
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.tsbuildinfo
next-env.d.ts
.vercel/

# Project-specific local docs / assistant files
CLAUDE.md
